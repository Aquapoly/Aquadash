# Aquadash Backend Environment Variables

# Deployment Mode
# Set to 1 for Docker, 0 for native Python
DOCKER=1

# Development Mode
# Set to 1 to enable hot reload via docker-compose.dev.yml
DEV=0

# Camera Configuration
# Set the logical name of the camera to use (must be created in camera-daemon first)
CAMERA_NAME=camera0

# Set the device path for the camera (e.g., /dev/video0)
CAMERA_DEVICE=/dev/video0
