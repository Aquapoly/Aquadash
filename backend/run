#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# --- Load .env ---
if [[ ! -f .env ]]; then
    echo "[Error] .env file not found"
    echo "  Copy .env.example to .env and configure settings:"
    echo "      cp .env.example .env"
    exit 1
fi

set -a
source .env
set +a

echo "[Info] Loaded configuration from .env"

# --- Helpers ---
start_app() {
    echo "[Info] Starting app stack (db + app)..."
    docker compose up -d app $BUILD_FLAG
}

start_cam() {
    echo "[Info] Starting camera block..."

    if sudo systemctl is-active --quiet camera-daemon; then
        echo "[Info] camera-daemon already running"
    else
        echo "[Info] Starting camera-daemon..."
        sudo systemctl start camera-daemon
    fi

    if [[ -z "${CAMERA_NAME:-}" || -z "${CAMERA_DEVICE:-}" ]]; then
        echo "[Error] CAMERA_NAME and CAMERA_DEVICE must be set in .env"
        exit 1
    fi

    echo "[Info] Registering camera: ${CAMERA_NAME} on ${CAMERA_DEVICE}"
    if sudo camera-ctl list | grep -q "$CAMERA_NAME"; then
        echo "[Info] Camera ${CAMERA_NAME} already registered, skipping"
    else
        sudo camera-ctl create "$CAMERA_NAME" "$CAMERA_DEVICE"
    fi

    echo "[Info] Starting cam_client container..."
    docker compose up -d cam_client $BUILD_FLAG
}

# --- Dispatch ---
BUILD_FLAG=""
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --build) BUILD_FLAG="--build" ;;
        *) ARGS+=("$arg") ;;
    esac
done

MODE="${ARGS[0]:-all}"

case "$MODE" in
    app)
        start_app
        ;;
    cam)
        start_cam
        ;;
    all)
        start_app
        start_cam
        ;;
    *)
        echo "[Error] Unknown mode: $MODE"
        echo "Usage: $0 [app|cam|all] <--build>"
        echo "  (no argument defaults to 'all')"
        exit 1
        ;;
esac
